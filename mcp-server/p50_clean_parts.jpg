          if (screen.width < "800") {
            return;
          }
          let background = document.querySelector(".backgroundOverlayDark");
          background.style.opacity = ".5";
          background.style.zIndex = "100";
        });
        navlink.addEventListener("mouseout", (e) => {
          if (screen.width < "800") {
            return;
          }
          let background = document.querySelector(".backgroundOverlayDark");
          background.style.opacity = "0";
          background.style.zIndex = "-1";
