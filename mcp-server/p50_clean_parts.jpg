 <a href="#" onClick="set_cookie_policy(); return false;" style="font-size:13px;font-weight:bold;cursor:pointer;font-family:'Work Sans', sans-serif;line-height:1em;overflow:visible;padding:6px 10px;color:#fff;background-color:#222; border-radius:5px;border:1px solid #000; text-decoration:none ">Accept</a> <a href="https://www.parts-people.com/privacy.htm"  style="color: #666; font-weight:700; text-decoration:none; font-size:13px;">Read Policy</a></span></div>

<script>
//set cookie
function set_cookie_policy(){
document.cookie = "cookiePolicyAccepted=1; path=/"; 
	document.getElementById('cookie-policy-info-bar').style.display='none';
}
//get cookie
function getCookie(cname) {
  var name = cname + "=";
  var decodedCookie = decodeURIComponent(document.cookie);
  var ca = decodedCookie.split(';');
  for(var i = 0; i <ca.length; i++) {
    var c = ca[i];
    while (c.charAt(0) == ' ') {
      c = c.substring(1);
    }
    if (c.indexOf(name) == 0) {
      return c.substring(name.length, c.length);
    }
  }
  return "";
}
// Hide Bar if policy accepted 
var policyAccepted= getCookie("cookiePolicyAccepted");
if (policyAccepted == 1) {
document.getElementById('cookie-policy-info-bar').style.display='none';
}


