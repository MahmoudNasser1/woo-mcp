 <script>

let stminif = document.querySelector(".stminif");
let arrow = document.querySelector("#arrow");
let duration = 400; // time in ms

function showstMini() {

	 // calling the slideToggle function
slideToggle(stminif, duration);

// class toggle
if (arrow.classList.contains("down")) {
    arrow.classList.remove("down");
    arrow.classList.add("up");
} else {
    arrow.classList.remove("up");
    arrow.classList.add("down");
}
}



// define a slideToggle function
function slideToggle(element, duration = 500) {
    if(window.getComputedStyle(element).display === "none") {
        fadeIn(element, duration);
    } else {
        fadeOut(element, duration);
    }
}

// fadeIn function
function fadeIn(element, duration) {
    element.style.display = "block";
    element.style.opacity = 0;

    let last = +new Date();
    let tick = function() {
        element.style.opacity = +element.style.opacity + (new Date() - last) / duration;
        last = +new Date();

        if (+element.style.opacity < 1) {
            (window.requestAnimationFrame && requestAnimationFrame(tick)) || setTimeout(tick, 16);
        }
    };

    tick();
}

// fadeOut function
function fadeOut(element, duration) {
    element.style.opacity = 1;

    let last = +new Date();
    let tick = function() {
        element.style.opacity = +element.style.opacity - (new Date() - last) / duration;
        last = +new Date();

        if (+element.style.opacity > 0) {
            (window.requestAnimationFrame && requestAnimationFrame(tick)) || setTimeout(tick, 16);
        } else {
            element.style.display = "none";
        }
    };

    tick();
}







    document.querySelectorAll(".footer-container__line-title").forEach((navlink) => {
      navlink.addEventListener("click", (e) => {
        var toggleState = navlink.getAttribute("data-toggle");
        var elem = navlink;
        console.log(toggleState);

        if (toggleState == "closed") {
          navlink.setAttribute("data-toggle", "open");
          
          while ((elem = elem.nextElementSibling)) {
            if (elem.nodeType === 3) continue; // text node
            elem.style.display = "block";
          }
        } else if (toggleState == "open") {
          navlink.setAttribute("data-toggle", "closed");
          
          while ((elem = elem.nextElementSibling)) {
            if (elem.nodeType === 3) continue; // text node
            elem.style.display = "none";
          }
          
        }
      });
    });
  </script>

